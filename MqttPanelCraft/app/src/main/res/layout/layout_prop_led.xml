<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- SECTION 2: INTERACTION (MOVED TO TOP) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="@dimen/prop_section_icon_size"
            android:layout_height="@dimen/prop_section_icon_size"
            android:src="@drawable/ic_touch_app"
            app:tint="@color/props_primary"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:text="@string/properties_section_interaction"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/prop_text_secondary"
            android:letterSpacing="0.05"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- LED 模式選擇 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/prop_section_margin_bottom">

        <TextView
            android:text="@string/prop_label_led_type"
            android:textSize="12sp"
            android:textColor="@color/prop_text_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleLedLogicMode"
            android:layout_width="match_parent"
            android:layout_height="@dimen/prop_toggle_height"
            android:gravity="center"
            app:selectionRequired="true"
            app:singleSelection="true"
            app:checkedButton="@+id/btnLogicStandard">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogicStandard"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/val_led_logic_standard"
                android:padding="0dp"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogicRgb"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/val_led_logic_rgb"
                android:padding="0dp"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
        
        <TextView
            android:id="@+id/tvLogicModeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/prop_text_secondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="4dp"
            android:text="@string/desc_led_logic_standard" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <!-- 傳統模式區塊 -->
        <LinearLayout
            android:id="@+id/containerStandardMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 輸入列：左 40% 下拉選單 + 中間 50% 關鍵字輸入 + 右 10% 新增按鈕
                 gravity=top : 防止 error 出現時高度變動導致不對齊 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginBottom="8dp"
                android:baselineAligned="false">

                <!-- 40% 比對方式下拉選單 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/containerStandardMatchMode"
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="wrap_content"
                    android:hint="@string/prop_label_led_match_mode"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.App.TextInputLayout.Properties.Dropdown">

                    <AutoCompleteTextView
                        android:id="@+id/spStandardMatchType"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/prop_input_height_inner"
                        android:inputType="none"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:textColor="@color/prop_text_primary"
                        android:gravity="start|center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:popupBackground="@drawable/bg_popup_rounded"
                        android:dropDownVerticalOffset="4dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 50% 關鍵字輸入框
                     errorEnabled=true 預設保留 error 空間，防止高度變動 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/containerKeywordInputReal"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    android:layout_height="wrap_content"
                    android:hint="@string/prop_label_led_add_kw"
                    android:layout_marginStart="6dp"
                    app:errorEnabled="true"
                    style="@style/Widget.App.TextInputLayout.Properties">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etKeywordAdd"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/prop_input_height_inner"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:textSize="13sp"
                        android:textColor="@color/prop_text_primary"
                        android:maxLines="1"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 10% 新增按鈕 -->
                <ImageView
                    android:id="@+id/btnKeywordAdd"
                    android:layout_width="40dp"
                    android:layout_height="@dimen/prop_input_height_inner"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="8dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/props_primary"
                    android:padding="8dp"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="新增關鍵字"/>
            </LinearLayout>

            <!-- 關鍵字 Chip 氣泡列表 -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgLedKeywords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/prop_section_margin_bottom"
                app:chipSpacingHorizontal="4dp"
                app:chipSpacingVertical="4dp"/>
        </LinearLayout>
        
        <!-- RGB 模式區塊 -->
        <LinearLayout
            android:id="@+id/containerRgbMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/prop_section_margin_bottom"
                android:baselineAligned="false">

                <!-- 70% 比對方式切換按鈕 (32dp, 對齊 Selector 風格) -->
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/containerMatchMode"
                    android:layout_width="0dp"
                    android:layout_weight="7"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btnRgbMatchEqual">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRgbMatchEqual"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:text="@string/val_match_exact_alt"
                        android:textSize="11sp"
                        android:padding="0dp"
                        app:cornerRadius="@dimen/prop_toggle_corner_radius"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRgbMatchContain"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:text="@string/val_match_contains_alt"
                        android:textSize="11sp"
                        android:padding="0dp"
                        app:cornerRadius="@dimen/prop_toggle_corner_radius"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- 30% 狀態數量 Stepper (32dp, 對齊 Selector Stepper) -->
                <LinearLayout
                    android:id="@+id/containerRgbStepper"
                    android:layout_width="0dp"
                    android:layout_weight="3"
                    android:layout_height="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_outline"
                    android:paddingHorizontal="4dp"/>
            </LinearLayout>


            <!-- RGB Row 標頭 — 仿 Selector 的 LABEL|VALUE 設計語言 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.6"
                    android:layout_height="wrap_content"
                    android:text="@string/prop_label_led_color_active"
                    android:paddingStart="12dp"
                    android:textSize="10sp"
                    android:textColor="@color/prop_text_secondary"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="wrap_content"
                    android:text="@string/prop_label_led_keyword"
                    android:paddingStart="12dp"
                    android:textSize="10sp"
                    android:textColor="@color/prop_text_secondary"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerRgbStates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/prop_section_margin_bottom"/>
        </LinearLayout>
    </FrameLayout>

    <!-- 行為模式 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/prop_section_margin_bottom">

        <TextView
            android:text="@string/prop_label_led_action"
            android:textSize="12sp"
            android:textColor="@color/prop_text_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleLedActionMode"
            android:layout_width="match_parent"
            android:layout_height="@dimen/prop_toggle_height"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            app:selectionRequired="true"
            app:singleSelection="true"
            app:checkedButton="@+id/btnActionLatch">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActionLatch"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/val_led_action_latch"
                android:padding="0dp"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActionTimer"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/val_led_action_timer"
                android:padding="0dp"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/containerLedTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/prop_label_led_timer_hint"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            style="@style/Widget.App.TextInputLayout.Properties">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLedTimer"
                android:layout_width="match_parent"
                android:layout_height="@dimen/prop_input_height_inner"
                android:inputType="number"
                android:text="3000"
                android:textSize="14sp"
                android:textColor="@color/prop_text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 復原關鍵字區域 (仿觸發關鍵字) -->
        <LinearLayout
            android:id="@+id/containerRestoreKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/containerRestoreInputReal"
                    android:layout_width="0dp"
                    android:layout_weight="0.9"
                    android:layout_height="wrap_content"
                    android:hint="@string/prop_label_led_restore_kw_hint"
                    app:errorEnabled="true"
                    style="@style/Widget.App.TextInputLayout.Properties">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRestoreKeyword"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/prop_input_height_inner"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:textSize="13sp"
                        android:textColor="@color/prop_text_primary"
                        android:maxLines="1"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <ImageView
                    android:id="@+id/btnRestoreKwAdd"
                    android:layout_width="40dp"
                    android:layout_height="@dimen/prop_input_height_inner"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="8dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/props_primary"
                    android:padding="8dp"
                    android:background="?selectableItemBackgroundBorderless"/>
            </LinearLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgLedRestoreKeywords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:chipSpacingHorizontal="4dp"
                app:chipSpacingVertical="4dp"/>
        </LinearLayout>
        
        <TextView
            android:id="@+id/tvActionModeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/prop_text_secondary"
            android:lineSpacingExtra="2dp"
            android:text="" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_line"
        android:layout_marginBottom="@dimen/prop_section_margin_bottom" />

    <!-- SECTION 1: APPEARANCE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical"
        android:layout_marginBottom="@dimen/prop_section_margin_bottom">
        
        <ImageView
            android:layout_width="@dimen/prop_section_icon_size"
            android:layout_height="@dimen/prop_section_icon_size"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_palette"
            app:tint="@color/props_primary"
            android:layout_marginEnd="6dp"/>
            
        <TextView
            android:text="@string/properties_section_appearance"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/prop_text_secondary"
            android:letterSpacing="0.05"
            android:gravity="start|center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- 觸發效果 ToggleGroup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/prop_section_margin_bottom">

        <TextView
            android:text="@string/prop_label_led_effect"
            android:textSize="12sp"
            android:textColor="@color/prop_text_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleLedEffect"
            android:layout_width="match_parent"
            android:layout_height="@dimen/prop_toggle_height"
            android:gravity="center"
            app:selectionRequired="true"
            app:singleSelection="true"
            app:checkedButton="@+id/btnEffectNone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEffectNone"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/val_effect_steady_short"
                android:padding="0dp"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEffectBlink"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/val_effect_blink_short"
                android:padding="0dp"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <!-- Appearance Style & Colors Split Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:layout_marginBottom="@dimen/prop_section_margin_bottom"
        android:baselineAligned="false">

        <!-- Left 40%: Style Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_weight="0.4"
            android:layout_height="wrap_content"
            android:hint="@string/prop_label_led_visual_style_alt"
            android:layout_marginEnd="6dp"
            style="@style/Widget.App.TextInputLayout.Properties.Dropdown">

            <AutoCompleteTextView
                android:id="@+id/spLedStyle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/prop_input_height_inner"
                android:inputType="none"
                android:textSize="11sp"
                android:maxLines="1"
                android:textColor="@color/prop_text_primary"
                android:gravity="start|center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:popupBackground="@drawable/bg_popup_rounded"
                android:dropDownVerticalOffset="4dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Right 60%: Stacked Colors -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="0.6"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <!-- 發亮色 (僅限傳統模式) -->
            <FrameLayout
                android:id="@+id/containerActiveColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/prop_section_margin_bottom" />

            <!-- 常駐色 -->
            <FrameLayout
                android:id="@+id/containerIdleColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

    <!-- Appearance Mode Row - id 供風格切換時控制可見性 -->
    <LinearLayout
        android:id="@+id/containerApprModeRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:layout_marginBottom="@dimen/prop_section_margin_bottom">
        
        <!-- Mode Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_weight="0.4"
            android:layout_height="wrap_content"
            android:hint="@string/prop_label_led_content_mode"
            android:layout_marginEnd="6dp"
            style="@style/Widget.App.TextInputLayout.Properties.Dropdown">
            <AutoCompleteTextView
                 android:id="@+id/spPropApprMode"
                 android:layout_width="match_parent"
                 android:layout_height="@dimen/prop_input_height_inner"
                 android:inputType="none"
                 android:textSize="11sp"
                 android:maxLines="1"
                 android:textColor="@color/prop_text_primary"
                 android:gravity="start|center_vertical"
                 android:paddingStart="12dp"
                 android:paddingEnd="8dp"
                 android:popupBackground="@drawable/bg_popup_rounded"
                 android:dropDownVerticalOffset="4dp"/>
        </com.google.android.material.textfield.TextInputLayout>
        
        <!-- Mode Content: 使用 LinearLayout (垂直) 堆疊 Text+Icon，避免重疊 -->
        <LinearLayout
            android:id="@+id/containerPropRight"
            android:layout_width="0dp"
            android:layout_weight="0.6"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:orientation="vertical">
            
            <!-- Text Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/containerPropText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/prop_label_led_text_content"
                android:layout_marginTop="0dp"
                style="@style/Widget.App.TextInputLayout.Properties">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLedLabel"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/prop_input_height_inner"
                    android:inputType="text"
                    android:textSize="13sp"
                    android:textColor="@color/prop_text_primary"
                    android:maxLines="1"
                    android:singleLine="true"/>
            </com.google.android.material.textfield.TextInputLayout>
            
            <!-- Icon Container -->
            <LinearLayout
                android:id="@+id/containerPropIcon"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="2dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_palette_border"
                android:paddingHorizontal="4dp"
                android:visibility="gone">
                
                <ImageView android:id="@+id/iconPreviewLED1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="24dp" android:src="@drawable/ic_btn_power" app:tint="@color/prop_text_primary" android:tag="ic_btn_power" android:scaleType="fitCenter" android:layout_marginHorizontal="6dp"/>
                <ImageView android:id="@+id/iconPreviewLED2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="24dp" android:src="@drawable/ic_btn_lighting" app:tint="@color/prop_text_secondary" android:tag="ic_btn_lighting" android:scaleType="fitCenter" android:layout_marginHorizontal="6dp"/>
                <ImageView android:id="@+id/iconPreviewLED3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="24dp" android:src="@drawable/ic_btn_fan" app:tint="@color/prop_text_secondary" android:tag="ic_btn_fan" android:scaleType="fitCenter" android:layout_marginHorizontal="6dp"/>
                <ImageView android:id="@+id/iconPreviewLED4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="24dp" android:src="@drawable/ic_btn_play" app:tint="@color/prop_text_secondary" android:tag="ic_btn_play" android:scaleType="fitCenter" android:layout_marginHorizontal="6dp"/>
                <ImageView android:id="@+id/iconPreviewLED5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="24dp" android:src="@drawable/ic_btn_tune" app:tint="@color/prop_text_secondary" android:tag="ic_btn_tune" android:scaleType="fitCenter" android:layout_marginHorizontal="6dp"/>
                <ImageView android:id="@+id/iconPreviewLED6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="24dp" android:src="@drawable/ic_btn_energy" app:tint="@color/prop_text_secondary" android:tag="ic_btn_energy" android:scaleType="fitCenter" android:layout_marginHorizontal="6dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

